# ==============================================================
# UniHub Workshop — Biến môi trường Frontend (Vite)
# ==============================================================
# 1. Copy file này thành .env ở cùng thư mục:  cp .env.example .env
# 2. Điền giá trị thực tế vào .env (KHÔNG commit file .env lên Git)
# ==============================================================

# ----- API Backend -----
# URL gốc của Spring Boot backend, KHÔNG có dấu "/" ở cuối
VITE_API_BASE_URL=http://localhost:8080/api

# ----- Cloudinary (Upload ảnh) -----
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
