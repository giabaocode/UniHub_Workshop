# ==============================================================
# UniHub Workshop — Biến môi trường Frontend (Vite)
# ==============================================================
# 1. Copy file này thành .env ở cùng thư mục:  cp .env.example .env
# 2. Điền giá trị thực tế vào .env (KHÔNG commit file .env lên Git)
# 3. KHÔNG đặt API key bí mật ở đây — biến VITE_* sẽ bị bundle vào client.
# ==============================================================

# ----- API Backend -----
# Sử dụng đường dẫn tương đối vì đã cấu hình Proxy trong vite.config.js
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8081

# ----- Cloudinary (Upload ảnh / PDF) -----
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# ----- OAuth (CLIENT_ID là public, có thể để ở client) -----
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GITHUB_CLIENT_ID=your_github_client_id

# ----- AI Gemini -----
# AI key đã chuyển sang backend (env GEMINI_API_KEY của Spring Boot).
# KHÔNG còn VITE_GEMINI_API_KEY để tránh lộ key qua client bundle.
